  ___X___, ___K___, ___J___, ___G___, ___W___,      ___Z___, ___H___, LPAREN , RPAREN , __DOT__, \
                    NAV_SPC, NUMWORD, SPACE_L,      KC_BSLS, OS_LCTL,  OS_LSFT
*/

////// Horizontal combos
// top row left
