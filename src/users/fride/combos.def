//                         NAV_SPC, OS_MEH,    REPEAT, OS_LSFT

COMB( combo_canel,      CANCEL,         ___S___, ___I___)

COMB( CMB_BOOT,         QK_BOOT,        ___V___, _COMMA_)
COMB( CMB_NUMWORD,       NUMWORD,        NAV_SPC, OS_LSFT)

