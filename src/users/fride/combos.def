COMB(CMB_CIRC,    KC_CIRC,    ___F___, ___N___)
COMB(CMB_BSPC,    KC_BSPC,    _SQUOT_, _SLASH_)

COMB(CMB_LPRN,    KC_LPRN,    HM_D, KC_L)
COMB(CMB_LBRC,    KC_LBRC,    KC_G, HM_R)
COMB(CMB_RPRN,    KC_RPRN,    HM_N, KC_U)
COMB(CMB_RBRC,    KC_RBRC,    KC_H, HM_E)

COMB(CMB_ENT,     KC_ENT,     ___N___, ___E___, ___A___)
COMB(CMB_TAB,     KC_TAB,     ___T___, ___R___, ___D___)

